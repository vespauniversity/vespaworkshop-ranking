# Vespa Configuration
# Copy this file to .env and update with your actual values

# Vespa endpoint URL
# VESPA_ENDPOINT=https://xxxxx.yyyyyy.z.vespa-app.cloud
VESPA_ENDPOINT=https://<mTLS_ENDPOINT_DNS_GOES_HERE>

# Certificate paths for mTLS (required for Vespa Cloud)
# VESPA_CERT_PATH=/home/student/.vespa/your-tenant.your-app.default/data-plane-public-cert.pem
# VESPA_KEY_PATH=/home/student/.vespa/your-tenant.your-app.default/data-plane-private-key.pem

VESPA_CERT_PATH=/home/student/.vespa/<YOUR_TENANT>.<YOUR_APPLICATION>.default/data-plane-public-cert.pem
VESPA_KEY_PATH=/home/student/.vespa/<YOUR_TENANT>.<YOUR_APPLICATION>.default/data-plane-private-key.pem

# OpenAI Configuration (required for create_judgements.py)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Customize fields to return in search results (for evaluate.py)
# FIELDS_TO_RETURN=ProductID,ProductName,ProductBrand,Gender,Price,Description,PrimaryColor,AverageRating

# Optional: Number of documents to retrieve per query function (for create_judgements.py)
# Note: If using multiple query functions (hybrid search), this is the number per function
# Total documents evaluated = HITS × number_of_query_functions (before deduplication)
HITS=20

# Optional: Input/output file paths (for create_judgements.py)
# QUERIES_FILE=queries.csv
# JUDGEMENTS_FILE=judgements.csv
